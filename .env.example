# ============================================================================
# QARY Super-App — example env. Copy to .env and fill. NEVER commit secrets.
# ============================================================================

# ---------- App ----------
NODE_ENV=development
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:3000

# ---------- Database ----------
DATABASE_URL=postgresql://qary:qary@localhost:5432/qary
REDIS_URL=redis://localhost:6379

# ---------- Auth ----------
JWT_SECRET=change-me-in-prod-use-vault
JWT_REFRESH_SECRET=change-me-too
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
OTP_TTL_SECONDS=300
OTP_RATE_LIMIT_PER_HOUR=5

# ---------- Stripe (sandbox) ----------
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ---------- Maps ----------
MAPBOX_TOKEN=pk.xxx
# Optional fallback
GOOGLE_MAPS_API_KEY=

# ---------- Messaging (sandbox) ----------
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_FROM_SMS=+15550000000
TWILIO_FROM_WHATSAPP=whatsapp:+14155238886
SENDGRID_API_KEY=SG.xxx
SENDGRID_FROM_EMAIL=no-reply@qary.local

# ---------- Storage (S3-compatible / MinIO local) ----------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=qary-media
S3_PUBLIC_BASE_URL=http://localhost:9000/qary-media
SIGNED_URL_TTL_SECONDS=3600

# ---------- WebRTC ----------
TURN_URL=turn:localhost:3478
TURN_USERNAME=qary
TURN_PASSWORD=qary
STUN_URL=stun:stun.l.google.com:19302
SFU_ENABLED=false

# ---------- Agents (LLM) ----------
ANTHROPIC_API_KEY=sk-ant-xxx
AGENT_MODEL=claude-haiku-4-5
AGENT_RATE_LIMIT_PER_MIN=30
AGENT_VOICE_PIN_REQUIRED=true

# ---------- Security / retention ----------
EVIDENCE_RETENTION_DAYS=180
AUDIT_LOG_RETENTION_DAYS=365
RATE_LIMIT_GLOBAL_PER_MIN=120

# ---------- Observability ----------
LOG_LEVEL=info
SENTRY_DSN=
